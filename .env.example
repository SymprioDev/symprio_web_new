# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/symprio_db

# JWT secret key (change in production)
JWT_SECRET=your-secret-key-change-in-production

# Server port
PORT=5000

# Node environment
NODE_ENV=development

# Mistral AI API key (for AI Mode text chat)
MISTRAL_API_KEY=your-mistral-api-key

# ElevenLabs API key (for AI Mode voice agent)
